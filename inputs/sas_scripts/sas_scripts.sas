*********************************************************************************************;
*** RITM2637564 - Add NADAC, AAC, FUL to drug data
	- MADACBrand/NADACGeneric and FUL avail. 
	- AAC data is in the RMDP0_MEDICAID_PRICE table. We do not receive the data table in the weekly fdb files
	- 5/9/22 add to prod;
*********************************************************************************************;


%SYSMSTORECLEAR;
libname RXMAC "/sasdata/pharmacy/projects/RxReferences/macros";

options  SYMBOLGEN mprint mstored sasmstore=RXMAC compress=yes VALIDVARNAME=ANY nosyntaxcheck;

%RXLIB;

libname RXANA sqlsvr dsn="RXANA_PA"  schema="dbo" authdomain="BSC_DOM_AUTH" READBUFF=3000 DBMAX_TEXT=32000;

%let zip_loc=/sasdata3/pharmacy/projects/RxReferences/production/data/phi/fdb/zip;
%let raw_data=/sasdata3/pharmacy/projects/RxReferences/production/data/phi/fdb;

x rm -r "&raw_data./NDDF Plus DB/";
x unzip -u "&zip_loc./nddf_plus_db.zip" -d "&raw_data./";

x "unzip -u '&zip_loc./NDDF PLUS DDL.zip' -d '&raw_data./'";

x "find '&raw_data./NDDF Plus DB/' -type f >&raw_data./files.txt";

DATA FILES;
INFILE "&raw_data./files.txt" TRUNCOVER LRECL=25000;
	INPUT
		@1 FILE  $5000.;
FORMAT FULL_PATH PATH $2500. FDB_FILE $500. VERSION 8.1;
CALL SCAN(FILE, -1, POSITION, LENGTH,'/');
FULL_PATH=STRIP(TRANWRD(SUBSTR(FILE,1,POSITION-1),"&raw_data./NDDF Plus DB",""));
FDB_FILE=SUBSTR(FILE, POSITION, LENGTH);
VERSION=COMPRESS(FULL_PATH,,'KD')*.1;
CALL SCAN(FULL_PATH, 3, POSITION, LENGTH,'/');
PATH=SUBSTR(FULL_PATH,1,POSITION-1);
DROP POSITION LENGTH;
RUN;

x "rm &raw_data./files.txt";

PROC SORT DATA=FILES;
BY FDB_FILE VERSION;
RUN;

DATA LATEST_FILE;
SET FILES;
BY FDB_FILE VERSION;
IF LAST.FDB_FILE;
RUN;

x "find '&raw_data./NDDF Plus DDL/' -type f >&raw_data./files.txt";

DATA ANSI_SQL;
INFILE "&raw_data./files.txt" TRUNCOVER LRECL=25000;
	INPUT
		@1 FILE  $5000.;
IF FIND(FILE,"ANSI");
RUN;

x "rm &raw_data./files.txt";


%OBSCHECK(ANSI_SQL);

PROC DELETE DATA=ALL_SQL; RUN;

%MACRO SQL;
%DO CNT = 1 %TO &nobs. %BY 1;

DATA _NULL_;
SET ANSI_SQL(FIRSTOBS=&CNT. OBS=&CNT.);
CALL SYMPUTX('FILE',FILE); 
RUN;

DATA SQL;
RETAIN FDB_FILE CNT TYPE;
FORMAT FNAME FILE $5000. TYPE $10.;
INFILE "&FILE." TRUNCOVER FILENAME=FNAME LRECL=25000;
	INPUT
		@1 COMMAND  $5000.;
FORMAT PATH $2500. FDB_FILE $500. VERSION 8.1;
FILE=FNAME;
FORMAT FULL_PATH PATH $2500. FDB_FILE $500. VERSION 8.1;
CALL SCAN(FILE, -1, POSITION, LENGTH,'/');
FULL_PATH=STRIP(TRANWRD(SUBSTR(FILE,1,POSITION-1),"&raw_data./NDDF Plus DDL",""));
VERSION=COMPRESS(FULL_PATH,,'KD')*.1;

CALL SCAN(FULL_PATH, 3, POSITION, LENGTH,'/');
PATH=SUBSTR(FULL_PATH,1,POSITION-1);

IF FIND(COMMAND,"CREATE") OR FIND(COMMAND,"ALTER") THEN DO;
FDB_FILE=SCAN(COMMAND,3," ");
IF FIND(COMMAND,"CREATE") THEN TYPE="CREATE";
ELSE IF FIND(COMMAND,"ALTER") THEN TYPE="ALTER";
END;

IF FDB_FILE ^= ' ' AND COMMAND ^= ' ';
DROP POSITION LENGTH;
COMMAND=TRANWRD(COMMAND," DATE"," VARCHAR(10)");
CNT+1;
RUN;

PROC SORT DATA=SQL;
BY CNT FDB_FILE;
RUN;

PROC APPEND BASE=ALL_SQL DATA=SQL; RUN;

%END;

%MEND;

%SQL;

DATA KEEP1;
SET FILES;
IF FIND(FDB_FILE,'RNDC13') OR FIND(FDB_FILE,'RNDC14');
IF VERSION^=3 THEN FDB_FILE=TRANWRD(FDB_FILE,"_NDC_MSTR","");
RUN;

DATA KEEP2;
SET LATEST_FILE;
IF FDB_FILE IN
(
