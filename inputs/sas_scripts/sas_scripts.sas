%OBSCHECK(KEEP);

%MACRO CREATE;
%DO CNT = 1 %TO &NOBS. %BY 1;

DATA _NULL_;
SET KEEP(FIRSTOBS=&CNT. OBS=&CNT.);
CALL SYMPUTX('FILE',CATS("'",FILE,"'"));
CALL SYMPUTX('FDB_FILE',FDB_FILE);
CALL SYMPUTX('VERSION',PUT(VERSION,1.));
RUN;

PROC SQL;
SELECT STRIP(COMMAND)
INTO :CREATE_COMMAND SEPARATED BY ' '
FROM ALL_SQL
WHERE FDB_FILE="&FDB_FILE." AND PUT(VERSION,1.)="&VERSION." AND TYPE='CREATE'

ORDER BY CNT
;
QUIT;

%PUT &CREATE_COMMAND.;

PROC SQL;
CONNECT TO NETEZZA (server="npsexp01" database="ADH_SBX_RX_DATA" Authdomain="AD_Dom_Auth");
execute(DROP TABLE &FDB_FILE. IF EXISTS) by NETEZZA;
QUIT;

PROC SQL;
CONNECT TO NETEZZA (server="npsexp01" database="ADH_SBX_RX_DATA" Authdomain="AD_Dom_Auth");
execute(&CREATE_COMMAND.) by NETEZZA;
QUIT;

%END;

%MEND;

%CREATE;

%OBSCHECK(KEEP);

%MACRO LOAD;
%DO CNT = 1 %TO &NOBS. %BY 1;

DATA _NULL_;
SET KEEP(FIRSTOBS=&CNT. OBS=&CNT.);
CALL SYMPUTX('FILE',CATS("'",FILE,"'"));
CALL SYMPUTX('FDB_FILE',FDB_FILE);
CALL SYMPUTX('CREATE_COMMAND',CREATE_COMMAND);
CALL SYMPUTX('ALTER_COMMAND',ALTER_COMMAND);
RUN;

PROC SQL;
CONNECT TO NETEZZA (server="npsexp01" database="ADH_SBX_RX_DATA" Authdomain="AD_Dom_Auth");
execute(TRUNCATE &FDB_FILE.) by NETEZZA;
QUIT;

PROC SQL;
CONNECT TO NETEZZA (server="npsexp01" database="ADH_SBX_RX_DATA" Authdomain="AD_Dom_Auth");
execute(insert into &FDB_FILE.
select * from 
EXTERNAL &FILE.
USING
(   
    DATESTYLE 'YMD'
    DATEDELIM ''
    REMOTESOURCE ODBC
    LOGDIR '/sasdata3/pharmacy/projects/RxReferences/production/data/phi/fdb/'
	IGNOREZERO TRUE
);


) by NETEZZA;
QUIT;

%END;

%MEND;

%LOAD;

