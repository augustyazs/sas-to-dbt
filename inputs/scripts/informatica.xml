<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="04/13/2026 10:00:00" REPOSITORY_VERSION="187.93">
<REPOSITORY NAME="DEV_REPO" VERSION="187" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="PHARMACY" GROUP="" OWNER="admin" SHARED="SHARED">

  <!-- ============================================================ -->
  <!-- MAPPING: m_GLP1_Member_Classification                        -->
  <!-- Purpose: Classify members using GLP1 drugs for weight loss   -->
  <!--          or diabetes management                              -->
  <!-- ============================================================ -->
  <MAPPING DESCRIPTION="GLP1 Member Classification" ISVALID="YES"
           NAME="m_GLP1_Member_Classification" OBJECTVERSION="1">

    <!-- ============================================================ -->
    <!-- SOURCE DEFINITIONS                                           -->
    <!-- ============================================================ -->

    <SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="DW"
            DESCRIPTION="Pharmacy claims source table"
            NAME="pharmacy_claims" OBJECTVERSION="1" OWNERNAME="DW">
      <SOURCEFIELD DATATYPE="VARCHAR2" FIELDNUMBER="1"  FIELDWIDTH="20"
                   NAME="member_id"   NULLABLE="NOT NULL"/>
      <SOURCEFIELD DATATYPE="VARCHAR2" FIELDNUMBER="2"  FIELDWIDTH="15"
                   NAME="ndc"         NULLABLE="NOT NULL"/>
      <SOURCEFIELD DATATYPE="DATE"     FIELDNUMBER="3"  FIELDWIDTH="19"
                   NAME="fill_date"   NULLABLE="NOT NULL"/>
      <SOURCEFIELD DATATYPE="NUMBER"   FIELDNUMBER="4"  FIELDWIDTH="10" FIELDPRECISION="2"
                   NAME="quantity"    NULLABLE="NULL"/>
      <SOURCEFIELD DATATYPE="NUMBER"   FIELDNUMBER="5"  FIELDWIDTH="5"
                   NAME="days_supply" NULLABLE="NULL"/>
    </SOURCE>

    <SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="DW"
            DESCRIPTION="Medical claims and diagnosis source table"
            NAME="medical_claims" OBJECTVERSION="1" OWNERNAME="DW">
      <SOURCEFIELD DATATYPE="VARCHAR2" FIELDNUMBER="1" FIELDWIDTH="20"
                   NAME="member_id"    NULLABLE="NOT NULL"/>
      <SOURCEFIELD DATATYPE="VARCHAR2" FIELDNUMBER="2" FIELDWIDTH="10"
                   NAME="dx_code"      NULLABLE="NULL"/>
      <SOURCEFIELD DATATYPE="DATE"     FIELDNUMBER="3" FIELDWIDTH="19"
                   NAME="service_date" NULLABLE="NULL"/>
      <SOURCEFIELD DATATYPE="VARCHAR2" FIELDNUMBER="4" FIELDWIDTH="10"
                   NAME="claim_id"     NULLABLE="NOT NULL"/>
    </SOURCE>

    <!-- ============================================================ -->
    <!-- TARGET DEFINITION                                            -->
    <!-- ============================================================ -->

    <TARGET BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="DW"
            DESCRIPTION="Final GLP1 member classification output"
            NAME="glp1_member_classification" OBJECTVERSION="1" OWNERNAME="DW">
      <TARGETFIELD DATATYPE="VARCHAR2" FIELDNUMBER="1" FIELDWIDTH="20"
                   NAME="member_id"      NULLABLE="NOT NULL"/>
      <TARGETFIELD DATATYPE="VARCHAR2" FIELDNUMBER="2" FIELDWIDTH="15"
                   NAME="ndc"            NULLABLE="NULL"/>
      <TARGETFIELD DATATYPE="DATE"     FIELDNUMBER="3" FIELDWIDTH="19"
                   NAME="fill_date"      NULLABLE="NULL"/>
      <TARGETFIELD DATATYPE="VARCHAR2" FIELDNUMBER="4" FIELDWIDTH="25"
                   NAME="drug_category"  NULLABLE="NULL"/>
      <TARGETFIELD DATATYPE="NUMBER"   FIELDNUMBER="5" FIELDWIDTH="1"
                   NAME="has_diabetes_dx" NULLABLE="NULL"/>
      <TARGETFIELD DATATYPE="VARCHAR2" FIELDNUMBER="6" FIELDWIDTH="40"
                   NAME="final_category" NULLABLE="NULL"/>
    </TARGET>

    <!-- ============================================================ -->
    <!-- TRANSFORMATIONS                                              -->
    <!-- ============================================================ -->

    <!-- Source Qualifier: pharmacy_claims -->
    <TRANSFORMATION DESCRIPTION="Source qualifier for pharmacy claims filtered to GLP1 NDCs"
                    NAME="SQ_pharmacy_claims" OBJECTVERSION="1"
                    REUSABLE="NO" TYPE="Source Qualifier">
      <TRANSFORMFIELD DATATYPE="string"   NAME="member_id"   PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="string"   NAME="ndc"         PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="date/time" NAME="fill_date"  PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="decimal"  NAME="quantity"    PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="integer"  NAME="days_supply" PORTTYPE="OUTPUT"/>
      <TABLEATTRIBUTE NAME="Sql Query" VALUE="
        SELECT member_id, ndc, fill_date, quantity, days_supply
        FROM DW.pharmacy_claims
        WHERE fill_date BETWEEN TO_DATE('2023-01-01','YYYY-MM-DD')
                            AND TO_DATE('2023-12-31','YYYY-MM-DD')
          AND ndc IN (
            '0169-7501-12','0169-7501-13','0169-7501-14',
            '0169-3935-11','0169-3936-11','0169-3937-11',
            '00002-8215-01','00002-8215-59',
            '00173-7085-01','00173-7085-02',
            '00024-0590-30','00024-0591-30'
          )"/>
    </TRANSFORMATION>

    <!-- Source Qualifier: medical_claims -->
    <TRANSFORMATION DESCRIPTION="Source qualifier for medical claims filtering diabetes ICD-10 codes"
                    NAME="SQ_medical_claims" OBJECTVERSION="1"
                    REUSABLE="NO" TYPE="Source Qualifier">
      <TRANSFORMFIELD DATATYPE="string"    NAME="member_id"    PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="string"    NAME="dx_code"      PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="date/time" NAME="service_date" PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="string"    NAME="claim_id"     PORTTYPE="OUTPUT"/>
      <TABLEATTRIBUTE NAME="Sql Query" VALUE="
        SELECT DISTINCT member_id
        FROM DW.medical_claims
        WHERE SUBSTR(dx_code, 1, 3) IN ('E08','E09','E10','E11','E13')"/>
    </TRANSFORMATION>

    <!-- Joiner: LEFT JOIN pharmacy to diabetes members -->
    <TRANSFORMATION DESCRIPTION="Left join GLP1 rx claims to distinct diabetes diagnosis members"
                    NAME="JNR_glp1_diabetes" OBJECTVERSION="1"
                    REUSABLE="NO" TYPE="Joiner">
      <TRANSFORMFIELD DATATYPE="string"    NAME="member_id"    PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="string"    NAME="ndc"          PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="date/time" NAME="fill_date"    PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="integer"   NAME="days_supply"  PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="string"    NAME="dx_member_id" PORTTYPE="INPUT"/>
      <TABLEATTRIBUTE NAME="Join Type"      VALUE="Left Outer"/>
      <TABLEATTRIBUTE NAME="Join Condition" VALUE="SQ_pharmacy_claims.member_id = SQ_medical_claims.member_id"/>
      <TABLEATTRIBUTE NAME="Master Source"  VALUE="SQ_medical_claims"/>
    </TRANSFORMATION>

    <!-- Expression: derive drug_category, has_diabetes_dx, final_category -->
    <TRANSFORMATION DESCRIPTION="Derive drug category and final classification"
                    NAME="EXP_classify" OBJECTVERSION="1"
                    REUSABLE="NO" TYPE="Expression">
      <TRANSFORMFIELD DATATYPE="string"  NAME="member_id"      PORTTYPE="INPUT/OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="string"  NAME="ndc"            PORTTYPE="INPUT/OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="date/time" NAME="fill_date"    PORTTYPE="INPUT/OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="string"  NAME="dx_member_id"   PORTTYPE="INPUT"/>
      <TRANSFORMFIELD DATATYPE="string"  NAME="drug_category"  PORTTYPE="OUTPUT"
        EXPRESSION="IIF(ndc IN ('0169-7501-12','0169-7501-13','0169-7501-14'),
                        'Weight Loss GLP1',
                    IIF(ndc IN ('0169-3935-11','0169-3936-11','0169-3937-11',
                                '00002-8215-01','00002-8215-59',
                                '00173-7085-01','00173-7085-02',
                                '00024-0590-30','00024-0591-30'),
                        'Diabetes GLP1', NULL))"/>
      <TRANSFORMFIELD DATATYPE="integer" NAME="has_diabetes_dx" PORTTYPE="OUTPUT"
        EXPRESSION="IIF(ISNULL(dx_member_id), 0, 1)"/>
      <TRANSFORMFIELD DATATYPE="string"  NAME="final_category"  PORTTYPE="OUTPUT"
        EXPRESSION="IIF(drug_category = 'Weight Loss GLP1',
                        'Weight Loss',
                    IIF(drug_category = 'Diabetes GLP1' AND has_diabetes_dx = 1,
                        'Diabetes Management',
                    IIF(drug_category = 'Diabetes GLP1' AND has_diabetes_dx = 0,
                        'Likely Weight Loss', NULL)))"/>
    </TRANSFORMATION>

    <!-- ============================================================ -->
    <!-- CONNECTOR MAPPINGS (data flow between transformations)       -->
    <!-- ============================================================ -->

    <CONNECTOR FROMFIELD="member_id"  FROMINSTANCE="SQ_pharmacy_claims"
               TOFIELD="member_id"   TOINSTANCE="JNR_glp1_diabetes"/>
    <CONNECTOR FROMFIELD="ndc"        FROMINSTANCE="SQ_pharmacy_claims"
               TOFIELD="ndc"         TOINSTANCE="JNR_glp1_diabetes"/>
    <CONNECTOR FROMFIELD="fill_date"  FROMINSTANCE="SQ_pharmacy_claims"
               TOFIELD="fill_date"   TOINSTANCE="JNR_glp1_diabetes"/>
    <CONNECTOR FROMFIELD="days_supply" FROMINSTANCE="SQ_pharmacy_claims"
               TOFIELD="days_supply"  TOINSTANCE="JNR_glp1_diabetes"/>
    <CONNECTOR FROMFIELD="member_id"  FROMINSTANCE="SQ_medical_claims"
               TOFIELD="dx_member_id" TOINSTANCE="JNR_glp1_diabetes"/>

    <CONNECTOR FROMFIELD="member_id"    FROMINSTANCE="JNR_glp1_diabetes"
               TOFIELD="member_id"     TOINSTANCE="EXP_classify"/>
    <CONNECTOR FROMFIELD="ndc"          FROMINSTANCE="JNR_glp1_diabetes"
               TOFIELD="ndc"           TOINSTANCE="EXP_classify"/>
    <CONNECTOR FROMFIELD="fill_date"    FROMINSTANCE="JNR_glp1_diabetes"
               TOFIELD="fill_date"     TOINSTANCE="EXP_classify"/>
    <CONNECTOR FROMFIELD="dx_member_id" FROMINSTANCE="JNR_glp1_diabetes"
               TOFIELD="dx_member_id"  TOINSTANCE="EXP_classify"/>

    <CONNECTOR FROMFIELD="member_id"      FROMINSTANCE="EXP_classify"
               TOFIELD="member_id"       TOINSTANCE="glp1_member_classification"/>
    <CONNECTOR FROMFIELD="ndc"            FROMINSTANCE="EXP_classify"
               TOFIELD="ndc"             TOINSTANCE="glp1_member_classification"/>
    <CONNECTOR FROMFIELD="fill_date"      FROMINSTANCE="EXP_classify"
               TOFIELD="fill_date"       TOINSTANCE="glp1_member_classification"/>
    <CONNECTOR FROMFIELD="drug_category"  FROMINSTANCE="EXP_classify"
               TOFIELD="drug_category"   TOINSTANCE="glp1_member_classification"/>
    <CONNECTOR FROMFIELD="has_diabetes_dx" FROMINSTANCE="EXP_classify"
               TOFIELD="has_diabetes_dx"  TOINSTANCE="glp1_member_classification"/>
    <CONNECTOR FROMFIELD="final_category" FROMINSTANCE="EXP_classify"
               TOFIELD="final_category"   TOINSTANCE="glp1_member_classification"/>

  </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>